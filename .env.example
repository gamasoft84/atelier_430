# =============================================
# ATELIER 430 — Variables de entorno (template)
# =============================================
# Copia este archivo a .env y llena tus credenciales

# ---------------------------------------------
# Next.js
# ---------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME="Atelier 430"

# ---------------------------------------------
# Supabase — https://supabase.com/dashboard
# Proyecto > Settings > API
# ---------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=xxxxx
SUPABASE_SERVICE_ROLE_KEY=xxxxx

# ---------------------------------------------
# Cloudinary — https://cloudinary.com/console
# ---------------------------------------------
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=atelier430
CLOUDINARY_API_KEY=xxxxx
CLOUDINARY_API_SECRET=xxxxx
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=atelier430_uploads

# ---------------------------------------------
# Anthropic Claude API — https://console.anthropic.com
# IMPORTANTE: Es la API de pago, NO Claude Pro
# ---------------------------------------------
ANTHROPIC_API_KEY=sk-ant-xxxxx
ANTHROPIC_MODEL=claude-sonnet-4-6

# ---------------------------------------------
# Resend — https://resend.com/api-keys
# ---------------------------------------------
RESEND_API_KEY=re_xxxxx
RESEND_FROM_EMAIL=hola@atelier430.com
RESEND_REPLY_TO=tu-email@gamasoft.mx

# ---------------------------------------------
# WhatsApp Business
# Formato: 52 + 1 + 10 dígitos (sin espacios)
# Ejemplo: 5215512345678
# ---------------------------------------------
NEXT_PUBLIC_WHATSAPP_NUMBER=521XXXXXXXXXX
NEXT_PUBLIC_WHATSAPP_DEFAULT_MESSAGE="Hola Atelier 430, me interesa una obra"

# ---------------------------------------------
# Admin
# ---------------------------------------------
ADMIN_EMAIL=rick@gamasoft.mx

# ---------------------------------------------
# Configuración del lote
# ---------------------------------------------
NEXT_PUBLIC_TOTAL_INVENTORY=430
NEXT_PUBLIC_LAUNCH_DATE=2026-05-01
